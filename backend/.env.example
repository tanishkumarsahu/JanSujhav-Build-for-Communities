# ============================================================================
# PRODUCTION-READY ENVIRONMENT CONFIGURATION
# JanSujhav: People's Priorities - Constituency Development Platform
# ============================================================================
# 
# IMPORTANT: 
# 1. Copy this file to .env and fill in actual values
# 2. Never commit .env to git (should be in .gitignore)
# 3. Use strong, random values for all secrets
# 4. Keep sensitive values in secure vaults (AWS Secrets Manager, Hashicorp Vault, etc.)
# 5. Rotate secrets regularly
#
# ============================================================================

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Port the backend server listens on (default: 5000)
# Production: Use port 443 with reverse proxy (nginx, CloudFlare, etc)
PORT=5000

# Node environment: development | production | staging | testing
# Production: MUST be "production" for security & performance optimizations
NODE_ENV=production

# Enable debug logging (true/false)
# Production: Set to "false" for performance and security
DEBUG=false

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL via Neon)
# ============================================================================

# Neon PostgreSQL connection string with SSL
# Format: postgresql://user:password@host:port/database?sslmode=require
# Get from: https://console.neon.tech
# Required: YES
# Security: Includes connection pooling & SSL encryption
DATABASE_URL=postgresql://user:password@your-endpoint-pooler.c-1.us-east-1.aws.neon.tech:5432/neondb?sslmode=require

# Database connection pool size
# Default: 10 | Production recommended: 20-50 (depending on load)
DB_POOL_SIZE=20

# Database connection timeout (milliseconds)
# Default: 3000 | Production recommended: 5000
DB_CONNECTION_TIMEOUT=5000

# Database idle timeout before connection closes (milliseconds)
# Default: 30000 | Production recommended: 60000
DB_IDLE_TIMEOUT=60000

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================

# JWT signing secret (min 32 characters, use strong random value)
# Generate: openssl rand -base64 32
# DO NOT use weak or predictable values in production
# Change this value to invalidate all existing tokens
JWT_SECRET=your_very_long_random_jwt_secret_here_minimum_32_characters_required_for_production

# JWT token expiration time
# Examples: "24h", "7d", "30d"
# Production recommended: "24h" or "7d" (shorter is more secure)
JWT_EXPIRES_IN=7d

# JWT refresh token expiration
# Should be longer than JWT_EXPIRES_IN
JWT_REFRESH_EXPIRES_IN=30d

# ============================================================================
# GOOGLE OAUTH 2.0 AUTHENTICATION
# ============================================================================

# Google OAuth Client ID
# Get from: https://console.cloud.google.com/apis/credentials
# Format: xxxxxxxx.apps.googleusercontent.com
# Required: For user authentication via Google
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Google OAuth Client Secret
# Get from: https://console.cloud.google.com/apis/credentials
# Security: Keep this HIGHLY SECRET, never expose in frontend
# Required: For server-side token validation
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Authorized redirect URI (must match Google Cloud Console)
# Production: https://yourdomain.com/auth/google/callback
GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/google/callback

# ============================================================================
# GEMINI AI (Google Generative AI)
# ============================================================================

# Gemini API Key
# Get from: https://makersuite.google.com/app/apikey
# Required: For LLM-powered features (proposal comparisons, content generation)
# Security: Keep this SECRET, use separate keys per environment
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini AI Model
# Production recommended: gemini-2.0-flash (fast & cost-effective)
# Other options: gemini-pro, gemini-pro-vision
# See: https://ai.google.dev/models
GEMINI_DEFAULT_MODEL=gemini-2.0-flash

# Gemini API rate limiting
# Max requests per minute
GEMINI_RATE_LIMIT_PER_MIN=60

# Gemini request timeout (seconds)
GEMINI_REQUEST_TIMEOUT=30

# ============================================================================
# NEWS & DATA POLLING
# ============================================================================

# GNews API Key (for constituency news aggregation)
# Get from: https://gnews.io
# Required: For news polling & ranking features
NEWS_API_KEY=your_gnews_api_key_here

# News API provider
# Supported: "gnews"
NEWS_API_PROVIDER=gnews

# News polling interval (minutes)
# How often to fetch latest news for all constituencies
# Production recommended: 15-30 minutes (balances freshness vs API calls)
NEWS_POLL_INTERVAL_MINUTES=15

# Max news articles to fetch per polling cycle
# Production recommended: 50-100
NEWS_MAX_ARTICLES_PER_CYCLE=100

# Proposal scoring cache refresh interval (minutes)
# Invalidates cached scores to reflect new suggestions
# Production recommended: 5-10 minutes
SCORING_CACHE_REFRESH_MINUTES=5

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================

# Frontend base URL (for CORS and redirects)
# Development: http://localhost:5173
# Production: https://yourdomain.com
FRONTEND_URL=https://yourdomain.com

# CORS allowed origins (comma-separated)
# Security: Only allow trusted domains in production
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================================================
# SECURITY & COMPLIANCE
# ============================================================================

# Enable HTTPS only cookies (set to true in production)
# Only send secure cookies over HTTPS
SECURE_COOKIES=true

# Same-site cookie policy
# Options: Strict | Lax | None
# Production recommended: Strict (most secure)
SAMESITE_COOKIES=Strict

# Enable CSRF protection
# Production: true
CSRF_PROTECTION_ENABLED=true

# Rate limiting - requests per minute per IP
# Production recommended: 60-100 for API, 10 for auth endpoints
RATE_LIMIT_GENERAL=100
RATE_LIMIT_AUTH=10
RATE_LIMIT_PROPOSALS=50

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

# Log level: error | warn | info | debug
# Production recommended: info or warn
LOG_LEVEL=info

# Sentry error tracking (optional, for production monitoring)
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# New Relic monitoring (optional)
NEW_RELIC_LICENSE_KEY=your_new_relic_license_key_here
NEW_RELIC_APP_NAME=JanSujhav-Production

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable WhatsApp integration
WHATSAPP_INTEGRATION_ENABLED=false

# Enable AI comparison notes for proposals
AI_COMPARISON_NOTES_ENABLED=true

# Enable news aggregation
NEWS_AGGREGATION_ENABLED=true

# Maximum proposals to rank per request
MAX_PROPOSALS_TO_RANK=50

# ============================================================================
# PERFORMANCE & OPTIMIZATION
# ============================================================================

# Scoring cache TTL (seconds)
# 5 minutes = 300, 15 minutes = 900
SCORING_CACHE_TTL_SECONDS=300

# Ranking cache TTL (seconds)
RANKING_CACHE_TTL_SECONDS=300

# Comparison notes cache TTL (seconds)
# Longer TTL since comparisons are stable
COMPARISON_CACHE_TTL_SECONDS=900

# Enable query caching for database queries
DB_QUERY_CACHING_ENABLED=true

# ============================================================================
# BACKUP & MAINTENANCE
# ============================================================================

# Database backup configuration
# S3 bucket for backups
DB_BACKUP_S3_BUCKET=your-backup-bucket-name

# Backup frequency (daily | weekly)
DB_BACKUP_FREQUENCY=daily

# Automated maintenance window (UTC hour)
MAINTENANCE_WINDOW_HOUR=2

# ============================================================================
# DEPLOYMENT & INFRASTRUCTURE
# ============================================================================

# Cloud provider: aws | gcp | azure | heroku
CLOUD_PROVIDER=aws

# AWS region (if using AWS)
AWS_REGION=us-east-1

# Environment identifier (prod | staging | dev)
ENVIRONMENT=prod

# Application version (sync with package.json)
APP_VERSION=1.0.0

# ============================================================================
# OPTIONAL: THIRD-PARTY INTEGRATIONS
# ============================================================================

# Slack webhook for notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# SendGrid email service (for transactional emails)
SENDGRID_API_KEY=your_sendgrid_api_key_here

# ============================================================================
# IMPORTANT NOTES FOR PRODUCTION
# ============================================================================
#
# SECURITY CHECKLIST:
# ✓ All secrets are strong and random (min 32 characters)
# ✓ NODE_ENV is set to "production"
# ✓ JWT_SECRET is kept SECRET (use secrets management tool)
# ✓ CORS_ALLOWED_ORIGINS is restricted to your domain
# ✓ DATABASE_URL uses SSL/TLS
# ✓ SECURE_COOKIES is true
# ✓ Rate limiting is enabled
# ✓ Logging is set to appropriate level
#
# PERFORMANCE CHECKLIST:
# ✓ Database connection pool size is appropriate for load
# ✓ Caching TTLs are optimized
# ✓ News polling interval balances freshness vs API calls
# ✓ Rate limiting prevents abuse
#
# MONITORING CHECKLIST:
# ✓ Error tracking (Sentry) is configured
# ✓ Application monitoring (New Relic/DataDog) is enabled
# ✓ Database monitoring is in place
# ✓ Log aggregation (CloudWatch/ELK) is configured
#
# DEPLOYMENT CHECKLIST:
# ✓ Run "npm ci" (not npm install) for reproducible installs
# ✓ Run database migrations before deploying
# ✓ Enable auto-scaling for handling traffic spikes
# ✓ Set up CI/CD pipeline for automated testing
# ✓ Configure backup and disaster recovery
# ✓ Test load with production-like data
#
# ============================================================================
