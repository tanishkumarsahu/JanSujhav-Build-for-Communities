# ============================================================================
# PRODUCTION-READY FRONTEND ENVIRONMENT CONFIGURATION
# JanSujhav: People's Priorities - Constituency Development Platform
# ============================================================================
# 
# IMPORTANT: 
# 1. Copy this file to .env.local and fill in actual values
# 2. Never commit .env.local to git (should be in .gitignore)
# 3. Only non-sensitive, public values should go in .env files
# 4. Sensitive values should come from backend headers/API responses
# 5. For production builds: set VITE_NODE_ENV=production
#
# NOTE: Frontend env vars must be prefixed with VITE_ to be exposed to code
#
# ============================================================================

# ============================================================================
# API CONFIGURATION
# ============================================================================

# Backend API base URL
# Development: http://localhost:5000
# Production: https://api.yourdomain.com
VITE_API_BASE_URL=https://api.yourdomain.com

# API request timeout (milliseconds)
# Default: 30000 (30 seconds)
VITE_API_TIMEOUT=30000

# ============================================================================
# GOOGLE OAUTH 2.0
# ============================================================================

# Google OAuth Client ID (PUBLIC - safe to expose in frontend)
# Get from: https://console.cloud.google.com/apis/credentials
# This is the WEB CLIENT ID (NOT the Server/Backend one)
# Format: xxxxxxxx.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your_web_google_client_id.apps.googleusercontent.com

# Google OAuth scopes (comma-separated)
# Default scopes for email and profile access
VITE_GOOGLE_SCOPES=openid,email,profile

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Node environment: development | production | staging
# Production: MUST be "production"
VITE_NODE_ENV=production

# Application name
VITE_APP_NAME=JanSujhav

# Application version (should match package.json)
VITE_APP_VERSION=1.0.0

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable production mode (optimizations, error reporting)
VITE_PRODUCTION_MODE=true

# Enable error reporting to Sentry
VITE_SENTRY_ENABLED=false

# Enable analytics tracking
VITE_ANALYTICS_ENABLED=true

# Enable WhatsApp integration UI
VITE_WHATSAPP_ENABLED=false

# Enable MP dashboard
VITE_MP_DASHBOARD_ENABLED=true

# Enable news feed
VITE_NEWS_FEED_ENABLED=true

# Enable proposal ranking
VITE_PROPOSAL_RANKING_ENABLED=true

# ============================================================================
# UI/UX CONFIGURATION
# ============================================================================

# Default theme: light | dark | auto (follows system)
VITE_DEFAULT_THEME=light

# Items per page in lists/tables
VITE_ITEMS_PER_PAGE=20

# Default constituency (if any)
# Leave empty to show all or prompt user selection
VITE_DEFAULT_CONSTITUENCY=

# Map provider: google | openstreetmap
VITE_MAP_PROVIDER=openstreetmap

# ============================================================================
# MONITORING & ANALYTICS
# ============================================================================

# Sentry DSN for error tracking (frontend monitoring)
# Get from: https://sentry.io
# Leave empty to disable error reporting
VITE_SENTRY_DSN=

# Google Analytics ID
# Get from: https://analytics.google.com
VITE_GOOGLE_ANALYTICS_ID=

# Hotjar Site ID (optional, for heatmaps/recordings)
VITE_HOTJAR_ID=

# ============================================================================
# CACHE & PERFORMANCE
# ============================================================================

# Browser cache strategy: aggressive | moderate | minimal
# aggressive: Cache for 1 month
# moderate: Cache for 1 week
# minimal: Cache for 1 day
VITE_CACHE_STRATEGY=aggressive

# Enable service worker (offline support)
VITE_SERVICE_WORKER_ENABLED=true

# Service worker scope
VITE_SERVICE_WORKER_SCOPE=/

# ============================================================================
# SECURITY
# ============================================================================

# Content Security Policy headers
# Set via backend, but this controls frontend-side validation
VITE_CSP_ENABLED=true

# CORS credentials mode: include | same-origin | omit
# include: Send credentials (cookies) with requests
VITE_CORS_CREDENTIALS=include

# ============================================================================
# API ENDPOINTS (if not using VITE_API_BASE_URL)
# ============================================================================

# These can be left empty and built from VITE_API_BASE_URL
# Or specify individually for fine-grained control

# Proposals API endpoint
# Default: {VITE_API_BASE_URL}/api/proposals
VITE_PROPOSALS_ENDPOINT=

# News API endpoint
# Default: {VITE_API_BASE_URL}/api/news
VITE_NEWS_ENDPOINT=

# MP Info API endpoint
# Default: {VITE_API_BASE_URL}/api/mp
VITE_MP_ENDPOINT=

# Citizens API endpoint
# Default: {VITE_API_BASE_URL}/api/citizens
VITE_CITIZENS_ENDPOINT=

# ============================================================================
# LOCALIZATION
# ============================================================================

# Default language: en | hi | other
VITE_DEFAULT_LANGUAGE=en

# Supported languages (comma-separated)
VITE_SUPPORTED_LANGUAGES=en,hi

# Use browser language if supported
VITE_USE_BROWSER_LANGUAGE=true

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================

# Google Maps API Key (if using Google Maps)
# Get from: https://console.cloud.google.com/apis
VITE_GOOGLE_MAPS_API_KEY=

# Mapbox API Key (if using Mapbox instead of OpenStreetMap)
# Get from: https://www.mapbox.com
VITE_MAPBOX_ACCESS_TOKEN=

# ============================================================================
# LOGGING
# ============================================================================

# Log level: error | warn | info | debug | trace
# Production recommended: warn or error
VITE_LOG_LEVEL=warn

# Send logs to console
VITE_CONSOLE_LOGGING=true

# Send logs to server (backend endpoint for log aggregation)
VITE_SERVER_LOGGING_ENABLED=false
VITE_SERVER_LOG_ENDPOINT={VITE_API_BASE_URL}/api/logs

# ============================================================================
# BUILD CONFIGURATION
# ============================================================================

# Base path for production deployment
# If deploying to subdirectory, set this accordingly
# Default: /
VITE_BASE_PATH=/

# Source map generation for production
# true: Include source maps (larger bundle, helps debugging)
# false: No source maps (smaller bundle, recommended for production)
VITE_SOURCE_MAPS=false

# ============================================================================
# IMPORTANT NOTES FOR PRODUCTION
# ============================================================================
#
# SECURITY CHECKLIST:
# ✓ Only non-sensitive values in .env (frontend is public!)
# ✓ VITE_GOOGLE_CLIENT_ID is the WEB CLIENT, not Server client
# ✓ VITE_API_BASE_URL points to production backend
# ✓ VITE_PRODUCTION_MODE=true
# ✓ Source maps disabled (VITE_SOURCE_MAPS=false)
# ✓ CSP enabled (VITE_CSP_ENABLED=true)
#
# PERFORMANCE CHECKLIST:
# ✓ Cache strategy set to "aggressive"
# ✓ Service worker enabled for offline support
# ✓ Log level set to "warn" or "error"
# ✓ All feature flags are optimized
#
# DEPLOYMENT CHECKLIST:
# ✓ Run "npm run build" to create optimized production build
# ✓ Verify dist/ folder is not too large (should be <1MB gzipped)
# ✓ Test in production-like environment before deploying
# ✓ Configure CDN/cache headers via your hosting provider
# ✓ Enable HTTPS with valid SSL certificate
# ✓ Set up monitoring with error tracking (Sentry)
#
# BUILD COMMAND:
# npm run build
#
# PREVIEW PRODUCTION BUILD:
# npm run preview
#
# ============================================================================
